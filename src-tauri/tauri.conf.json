{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PCPanel",
  "version": "0.1.0",
  "identifier": "com.getpcpanel.PCPanel",
  "build": {
    "frontendDist": "./splash",
    "devUrl": "http://localhost:4200"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "label": "main",
        "width": 1100,
        "height": 800,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "resources": {
      "backend": "backend"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"],
        "files": {
          "/usr/lib/udev/rules.d/70-pcpanel.rules": "../packaging/linux/70-pcpanel.rules"
        }
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
